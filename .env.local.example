# Your Convex deployment URL — you'll get this by running `npx convex dev` for the first time.
# It will look like: https://happy-otter-123.convex.cloud
VITE_CONVEX_URL=

# Google OAuth Client ID for Google Contacts import.
# Create one at https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID (Web).
# Enable the People API and add your domain to Authorized JavaScript Origins.
VITE_GOOGLE_CLIENT_ID=
